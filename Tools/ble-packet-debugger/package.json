{
  "name": "@open-vitals/ble-packet-debugger",
  "version": "0.1.0",
  "private": true,
  "description": "Internal desktop BLE packet capture and decode workbench for OpenVitals.",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:renderer dev:main dev:electron",
    "dev:renderer": "vite --host 127.0.0.1 --port 5176 --strictPort",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on http://127.0.0.1:5176 dist/main/main/main.js dist/main/main/preload.js dist/main/main/bleHost.js && VITE_DEV_SERVER_URL=http://127.0.0.1:5176 electron .",
    "build": "tsc -p tsconfig.main.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "start": "npm run build && OPENVITALS_BLE_DEBUGGER_USE_BUILT=1 electron .",
    "probe:corebluetooth": "swiftc -framework Foundation -framework CoreBluetooth scripts/corebluetooth_probe.swift -o /tmp/openvitals-corebluetooth-probe && /tmp/openvitals-corebluetooth-probe"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-25",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
